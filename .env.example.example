# ============================================================================
# Task Management System - Environment Variables
# ============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
DB_HOST=database
DB_PORT=3306
DB_NAME=task_management
DB_USER=taskuser
DB_PASSWORD=changeme_taskpassword
DB_ROOT_PASSWORD=changeme_rootpassword

# ----------------------------------------------------------------------------
# Keycloak Configuration
# ----------------------------------------------------------------------------
# Internal URL (container-to-container)
KEYCLOAK_URL=http://keycloak:8080

# External URL (browser access)
KEYCLOAK_EXTERNAL_URL=http://localhost:8081

# Keycloak Realm & Client
KEYCLOAK_REALM=task-management
KEYCLOAK_CLIENT_ID=task-management-frontend

# Keycloak Admin Credentials
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_admin
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

# ----------------------------------------------------------------------------
# Email Configuration (SMTP)
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# ----------------------------------------------------------------------------
# Application URLs
# ----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:8080

# ----------------------------------------------------------------------------
# Port Configuration
# ----------------------------------------------------------------------------
# External ports (exposed to host)
NGINX_PORT=8080
KEYCLOAK_PORT=8081

# Internal ports (container-to-container)
BACKEND_PORT=5000
FRONTEND_INTERNAL_PORT=80

# ----------------------------------------------------------------------------
# React App Configuration (Build-time variables)
# ----------------------------------------------------------------------------
REACT_APP_KEYCLOAK_REALM=task-management
REACT_APP_KEYCLOAK_CLIENT_ID=task-management-frontend
